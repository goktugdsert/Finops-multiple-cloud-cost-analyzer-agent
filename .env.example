# =============================================================================
# mcca-agent — example environment configuration
#
# Copy to `.env` and fill in real values. `.env` is gitignored — NEVER commit it.
# All values are read at startup by src/mcca/config.py (pydantic-settings).
# =============================================================================

# --- Warehouse (Postgres) -----------------------------------------------------
# Points at the local Docker Compose Postgres by default (see docker-compose.yml).
# SQLAlchemy 2.0 + psycopg3 driver URL.
MCCA_DATABASE_URL=postgresql+psycopg://mcca:mcca@localhost:5432/mcca

# Values consumed by docker-compose.yml to provision that Postgres instance.
POSTGRES_USER=mcca
POSTGRES_PASSWORD=mcca
POSTGRES_DB=mcca
POSTGRES_PORT=5432

# --- AWS (READ-ONLY, least-privilege) ----------------------------------------
# The agent is READ-ONLY. Use a least-privilege billing role that grants only:
#   Cost Explorer read (ce:GetCostAndUsage, ce:Get*),
#   Cost & Usage Report read (cur:DescribeReportDefinitions + S3 read of the CUR bucket),
#   CloudWatch read (cloudwatch:GetMetricData, cloudwatch:ListMetrics).
# It must grant NO write/terminate permissions on any resource.
#
# Prefer a named profile or an assumed role over static keys. NEVER hardcode
# credentials in source. If you must use static keys, set them here (in .env only).
MCCA_AWS_REGION=us-east-1
# Payer/billing account id stamped onto Cost Explorer rows (CE omits it unless grouped
# by LINKED_ACCOUNT, and CE allows only 2 group-by dimensions). Falls back to 'unknown'.
# MCCA_AWS_BILLING_ACCOUNT_ID=123456789012
# MCCA_AWS_PROFILE=finops-readonly
# MCCA_AWS_ACCESS_KEY_ID=
# MCCA_AWS_SECRET_ACCESS_KEY=
# MCCA_AWS_SESSION_TOKEN=

# --- Agent LLM (reasoning only, never a source of figures) --------------------
# Provider is swappable here with NO code change. Options:
#   google    — Gemini, FREE tier (get a key at https://aistudio.google.com/apikey)
#   ollama    — a local model, free, no API key (needs Ollama running locally)
#   anthropic — Claude, best tool use, paid
#   openai    — GPT, paid
MCCA_LLM_PROVIDER=google
# MCCA_AGENT_MODEL=            # leave blank to use the provider's default model

# google (free tier):
# MCCA_GOOGLE_API_KEY=AIza...
# ollama (free, local):
# MCCA_OLLAMA_BASE_URL=http://localhost:11434
# anthropic / openai (paid):
# MCCA_ANTHROPIC_API_KEY=sk-ant-...
# MCCA_OPENAI_API_KEY=sk-...

# --- Langfuse (LLM tracing/observability) -------------------------------------
# Free cloud tier at https://cloud.langfuse.com, or self-host (set MCCA_LANGFUSE_HOST).
MCCA_LANGFUSE_ENABLED=false
# MCCA_LANGFUSE_PUBLIC_KEY=pk-lf-...
# MCCA_LANGFUSE_SECRET_KEY=sk-lf-...
MCCA_LANGFUSE_HOST=https://cloud.langfuse.com

# --- App ----------------------------------------------------------------------
MCCA_LOG_LEVEL=INFO
